# HUG 보증관리시스템 — Backend 환경변수 템플릿
# 실제 값은 backend_env_설정_260714.txt 참고 후 .env에 복사 (Git 커밋 금지)

APP_ENV=local
APP_NAME=hug-anshim-backend
API_V1_PREFIX=/api/v1
APP_PURPOSE=HUG보증관리시스템 해커톤 솔루션 개발

SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=dive2026

# --- 외부 API (데이터수집_및_API가이드 4장 연동 순서) ---

# ① 도로명주소 (business.juso.go.kr)
JUSO_API_KEY=
JUSO_API_EXPIRES_NOTE=승인키 유효기간 확인 필요

# ②③④ 공공데이터포털 공용 serviceKey (실거래가·건축물대장·사업자등록)
DATA_GO_KR_API_KEY=

# ⑤⑥⑦ 공시가격 3종 (디지털트윈국토/VWorld 인증키)
OFFICIAL_PRICE_APT_API_KEY=
OFFICIAL_PRICE_HOUSE_API_KEY=
OFFICIAL_PRICE_LAND_API_KEY=
OFFICIAL_PRICE_REGISTERED_SERVICE_URL=https://www.khug.or.kr/index.jsp

# ⑧ OpenDART
DART_API_KEY=

# ⑨ CODEF 등기부등본 — CODEF_ENV에 따라 아래 한 쌍만 사용
CODEF_ENV=sandbox
CODEF_DEMO_CLIENT_ID=
CODEF_DEMO_CLIENT_SECRET=
CODEF_SANDBOX_CLIENT_ID=
CODEF_SANDBOX_CLIENT_SECRET=
CODEF_PUBLIC_KEY_PATH=./secrets/codef_public_key.pem
CODEF_OAUTH_URL=https://oauth.codef.io/oauth/token
CODEF_DEMO_BASE_URL=https://development.codef.io
CODEF_SANDBOX_BASE_URL=https://sandbox.codef.io
CODEF_PROD_BASE_URL=https://api.codef.io

# ⑩ 온비드 (미발급 — Mock 사용)
ONBID_API_KEY=

# --- ML / RAG / Blockchain ---
ML_MODEL_DIR=./models
RAG_BACKEND=atlas_vector_search
OPENAI_API_KEY=
LLM_API_KEY=
EMBEDDING_MODEL_NAME=text-embedding-3-large
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=64
MONGODB_VECTOR_INDEX=rag_chunks_vector_index

BLOCKCHAIN_SERVICE_URL=
POLYGON_RPC_URL=
CONTRACT_ADDRESS=

# MOCK_MODE=true: API 실패 시 mock/ 폴더 JSON fallback
MOCK_MODE=true

# raw 응답 저장 경로 (프로젝트 루트 기준)
DATA_ROOT=../개별수집데이터 및 API

# --- 2026-07-15 FastAPI MVP 구현 시 추가된 항목 (기존 키는 값을 바꾸지 않고 그대로 둠) ---
# 건축HUB 건축물대장 상세 엔드포인트 (backend_env_설정_260714.txt에는 있었으나 .env.example엔 누락되어 있었음)
BUILDING_REGISTRY_ENDPOINT=/1613000/BldRgstHubService/getBrTitleInfo

# app/core/config.py Settings: 아래는 기존 키(SECRET_KEY, EMBEDDING_MODEL_NAME, EMBEDDING_DIMENSIONS,
# MONGODB_VECTOR_INDEX)와 함께 AliasChoices로 인식되므로 둘 중 하나만 채워도 된다. 새로 추가되는
# 항목(ATLAS_VECTOR_COLLECTION/PATH, BLOCKCHAIN_MODE, POLYGON_PRIVATE_KEY, POLYGON_CHAIN_ID,
# DEBUG, CORS_ALLOW_ORIGINS)은 이번에 신규로 쓰인다.
APP_DEBUG=true
CORS_ALLOW_ORIGINS=*

ATLAS_VECTOR_COLLECTION=rag_chunks
ATLAS_VECTOR_PATH=embedding

# 블록체인: 이번 MVP는 mock 모드만 구현. Polygon Amoy 실연동은 추후 개발.
BLOCKCHAIN_MODE=mock
POLYGON_PRIVATE_KEY=
POLYGON_CHAIN_ID=80002

# Blockchain_설계서_260714.md 24.3절이 "Backend 42장에 이미 존재"한다고 서술하지만 실제로는
# 어느 env 파일에도 없던 값(충돌사항). Node.js Anchor 서비스를 붙일 때 필요하며, 이번 Python
# mock adapter 단계에서는 사용하지 않는다.
INTERNAL_SERVICE_TOKEN=
